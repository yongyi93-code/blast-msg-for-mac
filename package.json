{
  "name": "whatsappblast",
  "version": "1.0.0",
  "description": "WhatsApp Blast Tool",
  "type": "commonjs",
  "main": "electron/main.js",
  "author": "WhatsApp Blast",
  "license": "MIT",
  "dependencies": {
    "express": "^4.19.2",
    "multer": "^2.1.1",
    "qrcode": "^1.5.4",
    "socket.io": "^4.7.5",
    "whatsapp-web.js": "^1.34.7",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.whatsappblast.app",
    "productName": "WhatsApp Blast Tool",
    "files": [
      "electron/**/*",
      "src/**/*",
      "public/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false
    },
    "directories": {
      "output": "dist"
    }
  },
  "scripts": {
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac"
  }
}
